  <body>
    
<nav id="navbar">
  <header>JavaScript Documentation</header>

  <a class="nav-link" href="#Introduction">Introduction</a>
  <a class="nav-link" href="#Variables">Variables</a>
  <a class="nav-link" href="#Functions">Functions</a>
