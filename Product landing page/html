<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="styles.css">
    <title>AeroAudio | Premium Sound</title>
</head>
<body>
    <header id="header">
        <img id="header-img" src="https://cdn.freecodecamp.org/testable-projects-fcc/images/product-landing-page-logo.png" alt="Company Logo">
        <nav id="nav-bar">
            <a class="nav-link" href="#features">Features</a>
            <a class="nav-link" href="#video-section">How it Works</a>
            <a class="nav-link" href="#pricing">Pricing</a>
        </nav>
    </header>

    <main>
        <section id="hero">
            <h2>Handcrafted Masterpieces</h2>
            <form id="form" action="https://www.freecodecamp.org/email-submit">
                <input type="email" id="email" name="email" placeholder="Enter your email address" required>
                <input type="submit" id="submit" value="Get Started">
            </form>
        </section>

        <section id="features">
            <div class="feat-box">
                <h3>Premium Materials</h3>
                <p>Our headphones use the finest leathers and metals.</p>
            </div>
        </section>

        <section id="video-section">
            <iframe id="video" src="https://www.youtube-nocookie.com/embed/y8Yv4pnO7qc" title="Product Video" frameborder="0" allowfullscreen></iframe>
        </section>

        <section id="pricing">
            <div class="product-card">
                <h3>The Solo</h3>
                <p>$100</p>
                <button>Select</button>
            </div>
        </section>
    </main>
</body>
</html>
